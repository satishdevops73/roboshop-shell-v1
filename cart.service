[Unit]
Description=RoboShop Cart Service
After=network.target

[Service]
Type=simple
User=appuser
WorkingDirectory=/app
ExecStart=/usr/bin/node server.js
Restart=on-failure
RestartSec=10
SyslogIdentifier=cart

Environment=REDIS_HOST=valkey-dev.kubek8.online
Environment=CATALOGUE_URL=http://catalogue-dev.kubek8.online:8002
Environment=PORT=8003

[Install]
WantedBy=multi-user.target